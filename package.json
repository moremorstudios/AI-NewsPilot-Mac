{
  "name": "ai-newspilot-desktop",
  "version": "1.0.0",
  "description": "NewsPilot Desktop (Offline-first)",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:mac:x64": "electron-builder --mac dmg zip --x64",
    "dist:mac:arm64": "electron-builder --mac dmg zip --arm64"
  },
  "devDependencies": {
    "electron": "40.0.0",
    "electron-builder": "26.5.0"
  },
  "build": {
    "appId": "MoremorStudios.AINewsPilot",
    "productName": "AI NewsPilot",
    "files": [
      "electron/**/*",
      "src/**/*",
      "tools/**/*",
      "models/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "tools/**",
      "models/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "openai": "^6.22.0",
    "undici": "^6.21.0",
    "electron-updater": "^6.6.2",
    "electron-log": "^5.3.0"
  },
  "author": "MoreMor LLC"
}
